# === LLM ===
ANTHROPIC_API_KEY=sk-ant-api03-...

# === Web Search ===
TAVILY_API_KEY=tvly-...

# === Database ===
# Async URL for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/research_db
# Sync URL for Alembic migrations & LangGraph checkpointer
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/research_db

# === Application ===
LOG_LEVEL=INFO
MAX_SEARCH_RESULTS=8
MAX_SOURCES_TO_EXTRACT=5
MAX_RETRIES=3
MODEL_NAME=claude-sonnet-4-6

# === Cost tracking (USD per 1K tokens — claude-sonnet-4-6) ===
COST_INPUT_PER_1K=0.003
COST_OUTPUT_PER_1K=0.015
