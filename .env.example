# === LLM — Groq (FREE) ===
# Sign up at https://console.groq.com → Dashboard → API Keys
GROQ_API_KEY=gsk_...

# === Web Search ===
# DuckDuckGo is used automatically — NO API key needed

# === Database ===
# SQLite file path — NO server or Docker required
SQLITE_PATH=research.db

# === Application ===
LOG_LEVEL=INFO
MAX_SEARCH_RESULTS=8
MAX_SOURCES_TO_EXTRACT=5
MAX_RETRIES=3
MODEL_NAME=llama-3.3-70b-versatile

# === Cost tracking (Groq free tier = $0) ===
COST_INPUT_PER_1K=0.0
COST_OUTPUT_PER_1K=0.0
